# ─── Steam & Accounts ────────────────────────────────────────────────────────
ACCOUNTS_FILE_PATH=./accounts.json
# Optional: AES encryption key for accounts.json at rest (leave blank to disable)
ACCOUNTS_ENCRYPTION_KEY=

DEFAULT_STEALTH_MODE=invisible

# ─── Games displayed in the UI (Label:appId|Label:appId) ────────────────────
GAME_OPTIONS=CS2:730|Dota 2:570|Team Fortress 2:440|Rust:252490

# ─── Steam reliability ────────────────────────────────────────────────────────
STEAM_LOGIN_INTERVAL_MS=3000
STEAM_BASE_RECONNECT_DELAY_MS=5000
STEAM_MAX_RECONNECT_DELAY_MS=300000
HEARTBEAT_INTERVAL_MS=30000
# Hard ceiling on simultaneous games per account (Steam limit = 32; > 10 logs a warning)
MAX_GAMES_PER_ACCOUNT=32

# ─── API / Dashboard ──────────────────────────────────────────────────────────
API_ENABLED=true
# Use 127.0.0.1 for local-only access, 0.0.0.0 to expose on LAN / Docker
API_HOST=127.0.0.1
API_PORT=3100
# Optional: if set, all /api/* routes require "Authorization: Bearer <token>"
API_TOKEN=

# Serve the built frontend from the backend process
DASHBOARD_STATIC_ENABLED=true
DASHBOARD_STATIC_DIR=./web/dist

# ─── Steam game search ────────────────────────────────────────────────────────
# Path for the Steam app list disk cache (fetched once every 24h, ~15 MB JSON)
GAME_DB_CACHE_FILE=./game-db.json

# ─── Alerting ─────────────────────────────────────────────────────────────────
# Optional: Discord webhook URL — alerts on account ERROR and pending Steam Guard
DISCORD_WEBHOOK_URL=

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=info
