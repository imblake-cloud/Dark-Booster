# ─── Required — review before first run ─────────────────────────────────────

# Port the dashboard and API listen on
API_PORT=3100

# 0.0.0.0 → accessible from your network / Docker port mapping
# 127.0.0.1 → local machine only
API_HOST=0.0.0.0

# Protect the dashboard with a secret token (recommended)
# If set, all /api/* requests require: Authorization: Bearer <your-token>
API_TOKEN=

# ─── Accounts ─────────────────────────────────────────────────────────────────

ACCOUNTS_FILE_PATH=./accounts.json

# Optional: AES-256 key to encrypt passwords stored in accounts.json
# Use any random string — if you lose it you will need to re-add all accounts
ACCOUNTS_ENCRYPTION_KEY=

# ─── Steam behaviour ──────────────────────────────────────────────────────────

# Default online status when an account connects
# Options: invisible | offline | normal
DEFAULT_STEALTH_MODE=invisible

# Game quick-select presets shown in the dashboard  (Label:appId|Label:appId)
GAME_OPTIONS=CS2:730|Dota 2:570|Team Fortress 2:440|Rust:252490

# Delay between sequential logins — avoids Steam rate limits (ms)
STEAM_LOGIN_INTERVAL_MS=3000

# Reconnect back-off: starts at BASE, doubles each retry, caps at MAX (ms)
STEAM_BASE_RECONNECT_DELAY_MS=5000
STEAM_MAX_RECONNECT_DELAY_MS=300000

# Session health-check interval (ms)
HEARTBEAT_INTERVAL_MS=30000

# Maximum simultaneous games per account — Steam hard limit is 32
MAX_GAMES_PER_ACCOUNT=32

# ─── Alerts (optional) ────────────────────────────────────────────────────────

# Discord webhook — sends alerts for Steam Guard prompts and account errors
# Create at: Server Settings → Integrations → Webhooks → New Webhook
DISCORD_WEBHOOK_URL=

# ─── Logging ──────────────────────────────────────────────────────────────────

# Options: debug | info | warn | error
LOG_LEVEL=info

# ─── Internal — do not change unless you know what you are doing ─────────────

DASHBOARD_STATIC_ENABLED=true
DASHBOARD_STATIC_DIR=./web/dist
