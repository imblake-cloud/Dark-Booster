{
  "name": "dark-booster",
  "version": "1.0.0",
  "description": "Dark Booster — self-hosted multi-account Steam hour booster",
  "private": true,
  "main": "dist/index.js",
  "type": "commonjs",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "pnpm run build:backend",
    "build:backend": "tsc -p tsconfig.json",
    "build:all": "pnpm run web:build && pnpm run build:backend",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "start:prod": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "web:dev": "pnpm --filter steam-hour-booster-web dev",
    "web:build": "pnpm --filter steam-hour-booster-web build",
    "web:preview": "pnpm --filter steam-hour-booster-web preview"
  },
  "dependencies": {
    "dotenv": "^16.6.1",
    "express": "^4.21.2",
    "pino": "^9.7.0",
    "steam-session": "^1.9.4",
    "steam-totp": "^2.1.2",
    "steam-user": "^5.3.0",
    "ws": "^8.18.0"
  },
  "pnpm": {
    "overrides": {
      "protobufjs": "^7.5.6"
    }
  },
  "devDependencies": {
    "@types/express": "^4.17.23",
    "@types/node": "^22.15.3",
    "@types/steam-totp": "^2.1.2",
    "@types/steam-user": "^5.1.1",
    "@types/ws": "^8.5.14",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
